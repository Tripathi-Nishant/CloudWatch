ENVIRONMENT=production
PORT=8000

# ── LLM (optional — rule-based fallback if not set)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Database (AWS RDS PostgreSQL) ─────────────────
# Get endpoint from RDS console after Step 2
DB_HOST=driftwatch-db.xxxxxxxxxx.ap-south-1.rds.amazonaws.com
DB_NAME=driftwatch
DB_USER=driftwatch_admin
DB_PASSWORD=DriftWatch2025!
DB_PORT=5432

# ── AWS ───────────────────────────────────────────
AWS_REGION=ap-south-1
EC2_PUBLIC_IP=your-ec2-public-ip

# S3 bucket for CSV uploads and fingerprints
S3_DATA_BUCKET=driftwatch-data-yourname

# SNS topic ARN for email alerts
# Get from SNS console after Step 4
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:driftwatch-drift-alerts

# SES verified email addresses
SES_FROM_EMAIL=your@email.com
ALERT_EMAIL=your@email.com

# ── Drift thresholds (optional — defaults shown) ──
PSI_WARNING_THRESHOLD=0.10
PSI_CRITICAL_THRESHOLD=0.20